{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -n --arg b \"$(git branch --show-current 2>/dev/null || echo unknown)\" '{systemMessage: (\"branch: \" + $b)}'"
          }
        ]
      }
    ]
  }
}
