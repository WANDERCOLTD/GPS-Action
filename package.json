{
  "name": "gps-action",
  "version": "0.2.261",
  "private": true,
  "packageManager": "pnpm@11.0.6",
  "description": "GPS Action — purpose-built platform for coordinated activism",
  "scripts": {
    "postinstall": "prisma generate",
    "predev": "prisma migrate deploy && prisma generate",
    "dev": "next dev -p ${PORT:-3001}",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:seed": "tsx scripts/seed.ts",
    "seed:demo": "tsx prisma/seed.ts && tsx scripts/seed.ts",
    "check:reference-data": "tsx scripts/check-reference-data.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "trace": "tsx scripts/trace.ts",
    "trace:check": "tsx scripts/trace.ts --check",
    "trace:matrix": "tsx scripts/trace.ts --matrix",
    "impact": "tsx scripts/trace.ts --impact",
    "trackers": "tsx scripts/generate-trackers.ts",
    "trackers:check": "tsx scripts/generate-trackers.ts --check",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@tanstack/react-query": "^5.100.10",
    "@trpc/client": "^11.17.0",
    "@trpc/next": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "date-fns": "^4.2.1",
    "date-fns-tz": "^3.2.0",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "pg": "^8.21.0",
    "psl": "^1.15.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "superjson": "^2.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.6",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.0",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-boundaries": "^6.0.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.3.3",
    "prisma": "^7.8.0",
    "tsx": "^4.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "type": "module",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
