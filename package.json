{
  "name": "gps-action",
  "version": "0.2.12",
  "private": true,
  "description": "GPS Action — purpose-built platform for coordinated activism",
  "scripts": {
    "predev": "prisma migrate deploy && prisma generate",
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:seed": "tsx scripts/seed.ts",
    "check:reference-data": "tsx scripts/check-reference-data.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "trace": "tsx scripts/trace.ts",
    "trace:check": "tsx scripts/trace.ts --check",
    "trace:matrix": "tsx scripts/trace.ts --matrix",
    "impact": "tsx scripts/trace.ts --impact",
    "trackers": "tsx scripts/generate-trackers.ts",
    "trackers:check": "tsx scripts/generate-trackers.ts --check",
    "prepare": "husky"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-query": "^5.100.5",
    "@trpc/client": "^11.0.0",
    "@trpc/next": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.11.0",
    "next": "^16.2.4",
    "pg": "^8.20.0",
    "psl": "^1.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "superjson": "^2.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@faker-js/faker": "^10.4.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.15.0",
    "eslint-config-next": "^16.2.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.3.3",
    "prisma": "^7.8.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "type": "module",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
