# ─── Database ──────────────────────────────────────────────────────────────
# Development: local Postgres. Production: AWS RDS eu-west-2.
DATABASE_URL="postgresql://user:password@localhost:5432/gps_action_dev"

# ─── Authentication ────────────────────────────────────────────────────────
# Signing key for session tokens. Generate with: openssl rand -base64 32
JWT_SECRET="change-me-generate-a-real-secret"
SESSION_MAX_AGE_SECONDS=900
REFRESH_TOKEN_MAX_AGE_SECONDS=2592000

# ─── Encryption ────────────────────────────────────────────────────────────
# AWS KMS key ARN for envelope encryption of Tier 1 personal data.
# See docs/process/security-baseline.md for data classification.
KMS_KEY_ID="arn:aws:kms:eu-west-2:ACCOUNT:key/KEY_ID"
AWS_REGION="eu-west-2"

# ─── Feature flags ─────────────────────────────────────────────────────────
# Defaults if flag service is offline.
DEFAULT_FLAGS="dispatch_modal:true,partner_orgs:false"

# ─── External services ─────────────────────────────────────────────────────
# Email provider (transactional only — not marketing)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
FROM_ADDRESS="notifications@gpsaction.org.uk"

# Error tracking (optional)
SENTRY_DSN=""

# ─── Development ───────────────────────────────────────────────────────────
NODE_ENV="development"
LOG_LEVEL="debug"

# Local dev server port. Default 3000 clashes with many other apps.
# 3001 is the project default. Override per-developer as needed.
PORT=3001

# Canonical origin used for outbound deep-links (e.g. the post URL
# embedded in a WhatsApp share). Falls back to window.location.origin
# in the browser, then to http://localhost:3001. Production must set
# this explicitly so share URLs point at the public host.
# See shared/site-origin.ts (BU-share-rail-on-detail).
NEXT_PUBLIC_SITE_ORIGIN="http://localhost:3001"

# GPS Network channel deep-link for the BU-tick-or-cross publish flow
# (D069). The post-publish modal copies the formatted message to the
# clipboard and opens this URL — WhatsApp Channels do NOT support
# `?text=` prefill, so the URL must be a bare deep-link. Format:
#   https://whatsapp.com/channel/<id>            (Channel)
#   https://chat.whatsapp.com/<invite>            (Group fallback)
# The validator throws at boot if missing in non-test environments.
WHATSAPP_NETWORK_CHANNEL_URL="https://chat.whatsapp.com/REPLACE_ME"

# ─── Network feed (BU-network-feed / ADR-0017) ─────────────────────────────
# Read-side surface for Grant (AIFA)'s WhatsApp-link feed at /network.
# These are SERVER-ONLY — the anon key never ships to the client bundle
# (the tRPC proxy in server/services/network.ts is the only consumer).
# Without these set, the surface returns an empty list. Feature flag
# `network_feed` is OFF in both prod and dev by default; flip via
# /data/featureFlag once the env is wired.
SUPABASE_URL=""
SUPABASE_ANON_KEY=""

# Server-side cache TTL for the upstream Supabase query, in seconds.
# Default 300 (5 min) — sized for the brief-locked volume of 5–10
# link-shares/day. The manual-refresh affordance bypasses the cache.
NETWORK_CACHE_TTL_SECONDS="300"
