// GPS Action — Database schema
//
// @build-unit BU-001-prep
// @spec architecture/admin-surface.md
// @spec architecture/claim-and-lease.md
// @spec product/region-and-proximity-decision.md
// @spec product/groups.md
// @spec product/post-creation-flow.md
// @adr D003 D022 D036 D038 D040 D041 D042 D043 D045 B07
//
// This file is the authoritative model of all entities. The visual ERD and
// rationale live in `docs/architecture/erd.md`. The slice convention (this
// file is extended one slice at a time, never refactored without an ADR) is
// documented in `prisma/schema.README.md`.
//
// Six conventions enforced by this schema (per admin-surface.md):
//   1. Every entity has a human-readable display field
//   2. Soft-delete-eligible entities have `deletedAt DateTime?`
//   3. Status / category / type fields use Prisma enums, never free-text
//   4. Every entity has `createdAt` and `updatedAt`
//   5. Every relation declares an explicit `onDelete` policy
//   6. Per-entity admin metadata lives in `server/admin/entity-metadata.ts`
//
// Slice 1: foundation entities — User, Region, UserRegion, WorkItem,
// RoleGrant, CoordinatorProfile, CoordinatorGroup, AuditLog, FeatureFlag.
// Slice 1.5: Groups entities — Group, GroupMembership + WorkItem.groupTags.
// Slice 2 (minimal): Post, PostVisibility — demo-path schema (PostType deferred per D048).
// Feature entities (Comment, Reaction, Flag, Application, etc.) arrive in
// Slices 2 (full)–4. See README for the slice plan.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// SLICE 1 — Foundation entities
// ─────────────────────────────────────────────────────────────────────────────

// ─── Enums ───────────────────────────────────────────────────────────────────

enum SystemRole {
  queue_manager
  admin
}

enum RegionType {
  national
  region
  council
}

enum RequestType {
  vetting
  flag
  outcome_review
  dedup_merge
  edit_request
  incident
  content_submission
  link_submission
  // D071 — post review request. Distinct from `vetting` (member admission).
  // Subject is a post artefact; verdict applies to Post.status + reviewedByUserId.
  kind_review
}

enum RequestStatus {
  unclaimed
  claimed
  in_review
  resolved
  abandoned
}

enum RequestPriority {
  low
  normal
  high
  urgent
}

enum RequestResolution {
  approved
  rejected
  edited
  escalated
  dismissed
  duplicate
  other
}

enum FeatureFlagPurpose {
  rollout
  kill_switch
  pilot_gate
}

// BU-tick-or-cross / D069. The author's amplify-or-flag choice on a
// `tick_or_cross` PostKind. Internal data only — member-facing copy
// uses ✅ / ❌ glyphs and never the words "promote" / "remove".
enum Signal {
  promote
  remove
}

// D071 — post lifecycle. Two values; discard remains soft-delete via
// Post.deletedAt; review state is the orthogonal Post.reviewRequestId
// flag (a post can be `draft` + reviewing or `published` + reviewing).
enum PostStatus {
  draft
  published
}

// D071 — drives the publish router's modal default per PostKind.
// review_first: Send-for-review is the only path
// review_after_publish: always publish, also send for review
// either_with_default_review_first: both available, "Send for review" preselected
// either_with_default_publish: both available, "Post to feed" preselected
enum ReviewMode {
  review_first
  review_after_publish
  either_with_default_review_first
  either_with_default_publish
}

// ─── User ────────────────────────────────────────────────────────────────────
//
// Identity for any human in the system. Per D041 — no location fields
// (homePostcode, lat/lng, location-permission). Auth implementation (NextAuth /
// Auth.js / Clerk / Lucia) is a separate Build Unit; this table only carries
// identity state.
//
// App-level invariants (not enforceable in Prisma):
//   - The last admin RoleGrant cannot be revoked
//   - A user cannot revoke their own admin role
//   - Soft-deleted users should not appear in default queries (router middleware
//     adds `WHERE deletedAt IS NULL`)
model User {
  id          String    @id @default(uuid())
  email       String    @unique
  displayName String
  // D071 — optional avatar URL. Phase 1 ships with initials fallback when
  // null; upload UI is a future BU. Initial demo data may set this via seed.
  avatarUrl   String?
  phoneNumber String?
  verifiedAt  DateTime?
  lastSeenAt  DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Region affinity (informational; per D041 not used for filtering)
  regionsOfInterest UserRegion[]

  // Requests (BU-requests-foundation — D054; renamed from WorkItem)
  requestsCreated  Request[] @relation("requestsCreated")
  requestsClaimed  Request[] @relation("requestsClaimed")
  requestsResolved Request[] @relation("requestsResolved")

  // Role grants
  roleGrants        RoleGrant[] @relation("roleGrants")
  roleGrantsMade    RoleGrant[] @relation("roleGrantsMade")
  roleGrantsRevoked RoleGrant[] @relation("roleGrantsRevoked")

  // Coordinator identity (one-to-one optional, per D042)
  coordinatorProfile CoordinatorProfile? @relation("coordinatorProfile")

  // Audit log
  auditEntriesActed AuditLog[] @relation("auditActor")
  auditEntriesAbout AuditLog[] @relation("auditTarget")

  // Groups (Slice 1.5 — D043)
  groupMemberships GroupMembership[] @relation("groupMemberships")
  groupsCreated    Group[]           @relation("groupsCreated")
  groupApprovals   GroupMembership[] @relation("groupApprovals")

  // Posts (Slice 2 minimal — D045)
  posts Post[] @relation("authorPosts")

  // D071 — posts this user has reviewed (kind_review verdict). Reverse of
  // Post.reviewedByUserId.
  postsReviewed Post[] @relation("PostReviewer")

  // Reactions authored (BU-reactions — D050)
  reactions Reaction[] @relation("authorReactions")

  // Comments authored (BU-comments — D052)
  comments Comment[] @relation("commentAuthor")

  // Feature flags
  featureFlagsOwned   FeatureFlag[] @relation("featureFlagsOwned")
  featureFlagsCreated FeatureFlag[] @relation("featureFlagsCreated")
  featureFlagsUpdated FeatureFlag[] @relation("featureFlagsUpdated")

  // System settings (BU-requests-urgent — D058)
  systemSettingsUpdated SystemSetting[] @relation("systemSettingsUpdated")

  // Notifications (BU-requests-vetting — D057)
  notificationsReceived Notification[] @relation("notificationsReceived")
  notificationsSent     Notification[] @relation("notificationsSent")

  // Coord-board (Slice 3 — bu-coordination-board / ADRs 0005-0009)
  assignments              Assignment[]          @relation("userAssignments")
  requestSubscriptions     RequestSubscription[] @relation("userSubscriptions")
  requestGroupSharedBy     RequestGroup[]        @relation("requestGroupSharedBy")
  groupShareWorkflowsAdded GroupShareWorkflow[]  @relation("groupShareWorkflowsAdded")

  @@index([deletedAt])
  @@index([verifiedAt])
}

// ─── Region ──────────────────────────────────────────────────────────────────
//
// Per D041 — hierarchy only. No centroids, no boundaries, no PostGIS. Used
// for tagging posts and for future council-action features. Slugs are stable
// public identifiers; displayName may be edited.
//
// App-level invariant: the parent chain is acyclic (enforced by router on
// create/update; not enforced by the database).
model Region {
  id          String     @id @default(uuid())
  slug        String     @unique
  displayName String
  type        RegionType

  parentId String?
  parent   Region?  @relation("regionHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children Region[] @relation("regionHierarchy")

  userRegions UserRegion[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([type])
  @@index([parentId])
  @@index([deletedAt])
}

// ─── UserRegion ──────────────────────────────────────────────────────────────
//
// Join table between User and Region. Semantics: regions a user has marked
// as relevant to their activism — informational display on their profile.
// Per D041 this does NOT drive feed or queue filtering in MVP. Future work
// may use this for an optional "filter my feed by my regions" preference
// (see parking-lot.md "Member region filtering").
//
model UserRegion {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  regionId String
  region   Region @relation(fields: [regionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, regionId])
  @@index([userId])
  @@index([regionId])
}

// ─── Request ─────────────────────────────────────────────────────────────────
//
// The unified "things needing decision/discussion" surface (D054, formerly
// WorkItem per D040). All claimable, single-worker workflows flow through
// this table; type-driven UI renders the right form per type.
//
// Renamed from WorkItem in BU-requests-foundation (D054). The status enum
// will collapse from five values to three (new / in_discussion / done) in
// a follow-up migration once the new statuses are wired through; for now
// the legacy five values remain to keep existing data compatible.
//
// App-level invariants:
//   - status='claimed' implies claimedByUserId, claimedAt, claimExpiresAt populated
//   - status='resolved' implies resolvedAt, resolvedByUserId, resolution populated
//   - regionSlug is informational only (per D041 not used for access control)
//   - Atomic claim: UPDATE ... WHERE status='unclaimed' (per claim-and-lease §"The race condition")
//   - Sweeper releases expired claims every 5 min (TTL + 4-hour cap)
model Request {
  id String @id @default(uuid())
  // ADR-0010 — nullable: kanban tickets (PR #2g.1+) carry `type = null`;
  // legacy reviewer flows (vetting, flag, kind_review, …) keep their value.
  type     RequestType?
  status   RequestStatus   @default(unclaimed)
  priority RequestPriority @default(normal)

  // Type-specific payload — references to underlying entities + display summary.
  // Per-type Zod schemas defined per Build Unit when each feature ships.
  context Json

  // Region tag — informational only in MVP (per D041)
  regionSlug String?

  // Group tags — array of Group slugs for queue filtering (Slice 1.5, D043)
  groupTags String[] @default([])

  // Lifecycle
  createdAt       DateTime @default(now())
  createdByUserId String?
  createdBy       User?    @relation("requestsCreated", fields: [createdByUserId], references: [id], onDelete: SetNull)

  // Claim fields (all nullable until a claim happens)
  claimedByUserId String?
  claimedBy       User?     @relation("requestsClaimed", fields: [claimedByUserId], references: [id], onDelete: SetNull)
  claimedAt       DateTime?
  claimExpiresAt  DateTime?
  lastHeartbeatAt DateTime?

  // Resolution fields (populated on resolve)
  resolvedAt       DateTime?
  resolvedByUserId String?
  resolvedBy       User?              @relation("requestsResolved", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  resolution       RequestResolution?
  resolutionNotes  String?

  // Urgent flag + kind (BU-requests-urgent — D058; D062 revision merges
  // AlertCategory into PostKind; FK renamed alertCategoryId → kindId).
  urgency          Boolean   @default(false)
  urgencyExpiresAt DateTime?
  kindId           String?
  kind             PostKind? @relation(fields: [kindId], references: [id], onDelete: SetNull)

  deletedAt DateTime?
  updatedAt DateTime  @updatedAt

  // Comments + notifications (BU-requests-vetting — D056, D057)
  comments      Comment[]      @relation("requestComments")
  notifications Notification[]

  // D071 — back-reference for `kind_review` requests linked from a Post.
  // 0..1 because Post.reviewRequestId is @unique. SetNull on delete via
  // the FK declared on Post.
  postReview Post? @relation("PostReviewRequest")

  // Coord-board (Slice 3 — bu-coordination-board / ADR-0005, ADR-0006, ADR-0009).
  // `columnId` is the originating group's BoardColumn placement; per-group
  // placements for shared groups live on `RequestGroup.columnId`.
  // `boardPosition` carries the originating group's manual reshuffle position.
  // Both nullable so existing Request rows (vetting, flag, kind_review, …) stay
  // valid; kanban rows populate them via service code in PR #2.
  columnId      String?
  column        BoardColumn? @relation(fields: [columnId], references: [id], onDelete: SetNull)
  boardPosition Decimal?

  assignments   Assignment[]
  requestGroups RequestGroup[]
  subscriptions RequestSubscription[]

  @@index([status, priority, createdAt])
  @@index([claimedByUserId, status])
  @@index([type, status])
  @@index([regionSlug, status])
  @@index([urgency, status])
  @@index([groupTags], type: Gin)
  @@index([deletedAt])
  @@index([columnId, boardPosition])
}

// ─── PostKind ────────────────────────────────────────────────────────────────
//
// BU-fab-intent-picker (D062 revised). Admin-managed table that backs
// every kind a Post can have AND every category an alert can carry.
// Single source of truth — replaces the original AlertCategory entity
// from D058 (which has been collapsed into this model).
//
// Code defines the slug set (the FAB picker tiles know which slugs to
// offer); admin manages per-row policy via isAlertEligible, displayName,
// sortOrder, and soft-delete. Slugs are the join key between code labels
// and DB rows — see D062 for the orthogonality model.
model PostKind {
  id              String    @id @default(uuid())
  slug            String    @unique
  displayName     String
  icon            String?
  sortOrder       Int       @default(0)
  isAlertEligible Boolean   @default(false)
  createdAt       DateTime  @default(now())
  deletedAt       DateTime?

  // D071 — publish-router config. Drives what the modal renders for this kind.
  // actionSlugs: which kind-specific actions render (resolved against the code
  //   registry at shared/post-kind-actions.ts; unknown slugs are inert).
  // reviewMode: drives the modal's preselected default + whether self-publish
  //   is even offered.
  // canSelfPublish: false hides the "Post to feed" base action.
  // reviewPriority: priority assigned to a kind_review Request created from
  //   this kind — high-stakes kinds bubble up the reviewer queue.
  actionSlugs    String[]        @default([])
  reviewMode     ReviewMode      @default(either_with_default_publish)
  canSelfPublish Boolean         @default(true)
  reviewPriority RequestPriority @default(normal)

  // D073 — when false, feed cards for posts of this kind suppress the
  // comment-peek row beneath the body. Cultural / tick_or_cross are
  // false; everything else true. Surfaced via the generic admin CRUD.
  feedCommentPeekEnabled Boolean @default(true)

  posts    Post[]
  requests Request[]

  @@index([deletedAt, sortOrder])
}

// ─── SystemSetting ───────────────────────────────────────────────────────────
//
// BU-requests-urgent / D058. Generic key/value admin settings. Seeded with
// urgent_ttl_hours=4 per D058 §4. Values stored as TEXT and parsed at read
// site (Number, JSON, etc) so the model is one row per logical setting.
model SystemSetting {
  id              String   @id @default(uuid())
  key             String   @unique
  value           String
  updatedAt       DateTime @updatedAt
  updatedByUserId String?
  updatedBy       User?    @relation("systemSettingsUpdated", fields: [updatedByUserId], references: [id], onDelete: SetNull)
}

// ─── RoleGrant ───────────────────────────────────────────────────────────────
//
// Dynamic role grants (D042). Active role test = exists RoleGrant where
// `revokedAt IS NULL`. Append-only in spirit — revocation is a status change
// (revokedAt + revokedReason), not a delete. No deletedAt; no soft delete.
//
// App-level invariants:
//   - One active grant per (user, role) — Postgres partial unique indexes are
//     not first-class in Prisma 5; enforced in the grant procedure (not at
//     DB level). Revisit with a raw-SQL migration if duplicates appear in
//     audit.
//   - Cannot revoke own admin role
//   - Cannot revoke the last admin
//   - On revocation: any work items claimed by the user are auto-released
//
// onDelete choices:
//   - user: Cascade (if a user is hard-deleted, drop their grant history)
//   - grantedBy: Restrict (an admin who granted roles cannot be hard-deleted
//     until those grants are reassigned/archived — preserves audit chain)
//   - revokedBy: Restrict (same reasoning)
model RoleGrant {
  id String @id @default(uuid())

  userId String
  user   User       @relation("roleGrants", fields: [userId], references: [id], onDelete: Cascade)
  role   SystemRole

  // Per-type scope (D055). Null = unscoped (the role applies broadly).
  // String form: e.g. "queue_manager:vetting", "queue_manager:flag",
  // "queue_manager:link_submission". Granular permissions on top of `role`.
  // Stored as TEXT (not enum) so admins can add scopes without migrations.
  scope String?

  grantedAt       DateTime @default(now())
  grantedByUserId String
  grantedBy       User     @relation("roleGrantsMade", fields: [grantedByUserId], references: [id], onDelete: Restrict)
  grantedReason   String

  revokedAt       DateTime?
  revokedByUserId String?
  revokedBy       User?     @relation("roleGrantsRevoked", fields: [revokedByUserId], references: [id], onDelete: Restrict)
  revokedReason   String?

  createdAt DateTime @default(now())

  @@index([userId, role, revokedAt])
  @@index([scope])
  @@index([grantedAt])
}

// ─── CoordinatorProfile ──────────────────────────────────────────────────────
//
// Per D042 — coordinator identity is data attached to a member, not a
// permission. Optional one-to-one with User. Self-claim with no verification
// in MVP (per M3a). Confers no special powers in GPS Action.
model CoordinatorProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation("coordinatorProfile", fields: [userId], references: [id], onDelete: Cascade)

  notes String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  groups CoordinatorGroup[]

  @@index([deletedAt])
}

// ─── CoordinatorGroup ────────────────────────────────────────────────────────
//
// External community a coordinator runs (a WhatsApp group, newsletter, shul
// network, etc.). Self-reported. `reachEstimate` and `reachVerifiedAt`
// foreshadow future analytics integration.
model CoordinatorGroup {
  id                   String             @id @default(uuid())
  coordinatorProfileId String
  coordinatorProfile   CoordinatorProfile @relation(fields: [coordinatorProfileId], references: [id], onDelete: Cascade)

  name            String
  description     String?
  logoUrl         String?
  reachEstimate   Int?
  reachVerifiedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([coordinatorProfileId, deletedAt])
}

// ─── AuditLog ────────────────────────────────────────────────────────────────
//
// Immutable, append-only record of sensitive events (per B07). No update, no
// delete, no soft-delete. Routers expose only insert + read; no update
// procedures must be written.
//
// `action` and `entityType` are open strings (not enums) because the action
// vocabulary extends per Build Unit — locking it in an enum would force a
// schema migration for every new auditable event. Documented values listed
// in B07.
//
// `userId` (actor) is nullable because some events are system-generated (e.g.
// claim_ttl_expired written by the sweeper).
//
// onDelete: SetNull for both actor and target so a user hard-delete leaves
// the audit chain intact.
model AuditLog {
  id String @id @default(uuid())

  action     String
  entityType String
  entityId   String

  userId String?
  user   User?   @relation("auditActor", fields: [userId], references: [id], onDelete: SetNull)

  targetUserId String?
  targetUser   User?   @relation("auditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  changes Json?
  context Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
  @@index([createdAt])
}

// ─── FeatureFlag ─────────────────────────────────────────────────────────────
//
// Homegrown, DB-driven feature flags (D036). Three purposes (rollout /
// kill_switch / pilot_gate) declared explicitly per flag. Evaluated
// server-side by `isFeatureEnabled(name, context)` (separate Build Unit;
// not implemented here).
//
// App-level invariants:
//   - New flags default `enabledGlobally=false`
//   - Rollout flags require `ttlRemoveAfter`
//   - Kill switches require `ownerUserId`
//   - Every flip writes an AuditLog entry (action: feature_flag_flipped)
//   - `enabledForGroupIds` references future Group entity (Slice 1.5);
//     stored as opaque strings for now since arrays cannot be FK-constrained
//     in Postgres anyway
//
// `enabledForRegions` holds region slugs (not IDs) for stability.
//
// onDelete choices: all User refs use Restrict so a user with active flags
// cannot be hard-deleted without first transferring ownership.
model FeatureFlag {
  id          String             @id @default(uuid())
  name        String             @unique
  description String
  purpose     FeatureFlagPurpose

  enabledGlobally    Boolean  @default(false)
  enabledForUserIds  String[] @default([])
  enabledForGroupIds String[] @default([])
  enabledForRegions  String[] @default([])
  rolloutPercentage  Int      @default(0)

  ttlRemoveAfter DateTime?

  ownerUserId String?
  owner       User?   @relation("featureFlagsOwned", fields: [ownerUserId], references: [id], onDelete: Restrict)

  createdAt       DateTime @default(now())
  createdByUserId String
  createdBy       User     @relation("featureFlagsCreated", fields: [createdByUserId], references: [id], onDelete: Restrict)

  updatedAt       DateTime @updatedAt
  updatedByUserId String
  updatedBy       User     @relation("featureFlagsUpdated", fields: [updatedByUserId], references: [id], onDelete: Restrict)

  deletedAt DateTime?

  @@index([purpose])
  @@index([enabledGlobally])
  @@index([ttlRemoveAfter])
  @@index([deletedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// SLICE 1.5 — Groups entities (D043)
// ─────────────────────────────────────────────────────────────────────────────

// ─── Enums ───────────────────────────────────────────────────────────────────

enum GroupJoinPolicy {
  open
  request_to_join
  admin_only
}

enum GroupMembershipRole {
  member
  // Tier-2 default #8 (bu-coordination-board v0.4): renamed from `lead`
  // 2026-05-04 — admin reads consistently across the kanban surface
  // ("group admin" vs "system admin"). Inline migration rides PR #1
  // schema bundle. See decision-log entry for the full mapping.
  admin
}

enum JoinSource {
  self_join
  request_approved
  admin_added
  admin_invited
}

// ─── Group ───────────────────────────────────────────────────────────────────
//
// Internal affiliation marker (D043). Members join groups to declare identity
// (e.g. "Writers", "Manchester", "BDS Response Team"). Groups enable soft
// queue filtering but do NOT grant permissions or fragment the feed (D041).
//
// Distinct from CoordinatorGroup (Slice 1) which represents external
// communities a coordinator runs outside GPS Action.
//
// App-level invariants:
//   - Slug is URL-safe and immutable after creation (renames update
//     displayName only — per groups.md §"Group naming conflicts")
//   - Soft-deleted groups don't appear in default queries
//   - createdBy user cannot be hard-deleted while the group exists (Restrict)
model Group {
  id          String  @id @default(uuid())
  slug        String  @unique
  displayName String
  description String?
  logoUrl     String?

  joinPolicy GroupJoinPolicy @default(open)
  isOfficial Boolean         @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdByUserId String
  createdBy       User   @relation("groupsCreated", fields: [createdByUserId], references: [id], onDelete: Restrict)

  // Coord-board (Slice 3 — bu-coordination-board / ADR-0006, ADR-0009).
  // `kind` drives default BoardColumn names per ADR-0006 (table 1).
  // Default `team` keeps existing Group rows valid post-migration; admins
  // can re-classify via the admin surface.
  kind GroupKind @default(team)

  boardColumns    BoardColumn[]
  requestGroups   RequestGroup[]       @relation("groupRequests")
  workflowSources GroupShareWorkflow[] @relation("workflowSources")
  workflowTargets GroupShareWorkflow[] @relation("workflowTargets")

  memberships GroupMembership[]

  @@index([deletedAt, isOfficial])
  @@index([kind])
}

// ─── GroupMembership ─────────────────────────────────────────────────────────
//
// Join table between User and Group. Tracks who belongs to which group, how
// they joined, and (if applicable) who approved them.
//
// App-level invariants:
//   - One active membership per (user, group) — active = leftAt IS NULL
//     AND deletedAt IS NULL. @@unique([userId, groupId]) enforces at DB
//     level; if a user re-joins after leaving, app logic creates a new row
//     (leftAt history preserved per groups.md)
//   - Cascade on both user and group FKs: if either is hard-deleted, the
//     membership row is removed
//   - approvedBy is SetNull: if the approving admin is hard-deleted, the
//     approval record persists with a null actor
model GroupMembership {
  id String @id @default(uuid())

  userId String
  user   User   @relation("groupMemberships", fields: [userId], references: [id], onDelete: Cascade)

  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  role GroupMembershipRole @default(member)

  joinedAt  DateTime   @default(now())
  joinedVia JoinSource @default(self_join)

  // Departure (domain event — member left voluntarily; row preserved for history)
  // Distinct from deletedAt: leftAt tracks a member choosing to leave;
  // deletedAt tracks an admin soft-deleting the record from default queries.
  leftAt     DateTime?
  leftReason String?

  // Approval tracking for request_to_join groups
  approvedByUserId String?
  approvedBy       User?     @relation("groupApprovals", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  approvedAt       DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([userId, groupId])
  @@index([userId])
  @@index([groupId, leftAt])
  @@index([deletedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// SLICE 2 (minimal) — Post schema for demo path (D045)
// ─────────────────────────────────────────────────────────────────────────────

// ─── Enums ───────────────────────────────────────────────────────────────────

enum PostVisibility {
  public // visible to anyone who can see the feed (including unauthed if we allow)
  authenticated_only // author chose to require login (D045 override)
}

// ─── Post ────────────────────────────────────────────────────────────────────
//
// Core content entity. A member writes a Post and it enters the feed.
// Minimum viable for the demo (ERD Slice 2 minimal). Full Slice 2
// (Comment, Reaction, Attachment, dedup) lands post-demo.
//
// Type field deferred — demo doesn't need branching on post type;
// full taxonomy lands with composer design. See ADR D048 and
// parking-lot.md "PostType taxonomy".
//
// App-level invariants:
//   - Posts with visibility='authenticated_only' must be filtered out
//     of any unauthenticated feed render
//   - activistMailerUrl must pass URL validation + domain allowlist
//     at the router layer (not enforced at DB)
//   - groupTags are slugs, not IDs — matches WorkItem convention;
//     informational only in MVP (per D041, D043)
//
// onDelete choices:
//   - author: Restrict (cannot hard-delete a user with posts; soft-
//     delete them instead to preserve community history)
model Post {
  id String @id @default(uuid())

  authorId String
  author   User   @relation("authorPosts", fields: [authorId], references: [id], onDelete: Restrict)

  title      String
  body       String
  visibility PostVisibility @default(public)

  activistMailerUrl String?

  // Link preview card data (BU-link-share — D060)
  linkUrl         String?
  linkTitle       String?
  linkDescription String?
  linkImageUrl    String?
  linkSiteName    String?

  // D075 — flagged-AM bit. True if this post is an Activist Mailer
  // email-action share. Auto-set at submit time when linkUrl matches
  // ACTIVIST_MAILER_ALLOWED_DOMAINS; member can manually override
  // either way. Drives the "Send email →" CTA on the link card and
  // the AM filter on /feed.
  isActivistMailer Boolean @default(false)

  // Member-picked hero image (BU-post-hero-demo — D064). Distinct from
  // linkImageUrl: linkImageUrl is fetched from the linked URL's og:image
  // and refreshes when linkUrl changes; heroImageUrl is explicitly chosen
  // by the member from the seeded demo set and is fixed once set. When
  // both are present, hero wins for the top-of-card slot. Demo path uses
  // a fixed allow-list (SEED_HERO_IMAGES); Phase 2 BU-image swaps that
  // for real upload + S3 + moderation without changing the field shape.
  heroImageUrl String?

  // Intent kind (BU-fab-intent-picker — D062). FK to managed PostKind table.
  // Code defines slugs; admin manages policy (isAlertEligible, displayName,
  // sortOrder) per row. See D062 for the orthogonality model.
  kindId String?
  kind   PostKind? @relation(fields: [kindId], references: [id], onDelete: SetNull)

  // Alert flag — orthogonal to kind (D062 revision). Composer enforces
  // that urgency=true is only allowed when the selected kind is
  // alert-eligible.
  urgency Boolean @default(false)

  // BU-tick-or-cross / D069. Author's amplify-or-flag choice for the
  // `tick_or_cross` kind. Required iff `kind.slug === 'tick_or_cross'`,
  // forbidden otherwise (service-layer invariant). Same shape D017
  // specified for `verdict`; deliberately renamed to `signal` because
  // the demo flow is post-publish handoff to a single channel, not the
  // multi-channel verdict routing D017 anticipated.
  signal Signal?

  // Timestamp of the explicit "I sent it" confirmation after the
  // post-publish WhatsApp handoff (BU-tick-or-cross / D069). Null until
  // confirmed; idempotent via `post.markSharedToNetwork`.
  sharedToNetworkAt DateTime?

  // D071 — post lifecycle (orthogonal to deletedAt and reviewRequestId).
  // status: draft = saved but not in feed; published = live in feed.
  // publishedAt: when the post became live (null while draft).
  status      PostStatus @default(draft)
  publishedAt DateTime?

  // D071 — review state (orthogonal to status). reviewRequestId set ⇒ post
  // has an open or closed kind_review Request; reviewedByUserId set ⇒ a
  // verdict has been applied (drives the three-tier attribution UI).
  reviewRequestId  String?  @unique
  reviewRequest    Request? @relation("PostReviewRequest", fields: [reviewRequestId], references: [id], onDelete: SetNull)
  reviewedByUserId String?
  reviewedBy       User?    @relation("PostReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  // Group tags — array of Group slugs (mirrors WorkItem pattern; informational only in MVP)
  groupTags String[] @default([])

  // BU-event-time / D073 / ADR-0001. Structured event-time data for
  // time-bearing kinds (meeting / event / happening_now per
  // kindIsTimeBearing in shared/post-kinds.ts). Optional for all kinds —
  // composer NUDGES with date/time pickers when the kind is time-
  // bearing but the server does not block submission when absent.
  // Storage: UTC. Render: Europe/London at the UI boundary via
  // date-fns-tz. Validation: when both timestamps are set,
  // eventEndsAt >= eventAt. locationText is free-form, <= 500 chars.
  eventAt      DateTime?
  eventEndsAt  DateTime?
  locationText String?

  // BU-calendar-near-me / D076 / ADR-0002. Structured event location
  // coordinates + online-event flag. `latitude` / `longitude` populated
  // by hand-coded seed entries (Path A); composer-side geocoding
  // (Path B) is deferred to a follow-up BU. `isOnline` lets online-only
  // events opt out of distance-based views (e.g. /calendar?view=near).
  // Storage: WGS84 decimal degrees as Float.
  latitude  Float?
  longitude Float?
  isOnline  Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Reactions on this post (BU-reactions — D050)
  reactions Reaction[] @relation("postReactions")

  // Comments on this post (BU-comments — D052)
  comments Comment[] @relation("postComments")

  @@index([visibility, createdAt(sort: Desc)])
  @@index([authorId, createdAt(sort: Desc)])
  @@index([groupTags], type: Gin)
  @@index([deletedAt])
  // BU-event-time / D073: index on eventAt for the listUpcoming query.
  // Plain B-tree is fine at MVP scale; promote to a partial index
  // (WHERE eventAt IS NOT NULL) later when the table grows.
  @@index([eventAt])
  // D071 — feed query: published posts ordered by publishedAt
  @@index([status, publishedAt(sort: Desc)])
  // D075 — feed AM filter
  @@index([isActivistMailer, createdAt(sort: Desc)])
  // BU-calendar-near-me / D076: composite index on (latitude, longitude)
  // for the near-me query. Plain B-tree is fine at MVP scale even
  // though most rows are NULL; promote to PostGIS / GiST later if the
  // table grows and we need real geospatial queries.
  @@index([latitude, longitude])
}

// ─── Reaction ────────────────────────────────────────────────────────────────
//
// BU-reactions (D050). Quiet, multi-select reactions on posts. The
// targetType + targetId pair is polymorphic so the same primitive
// covers comments (BU-007) when comments ship — at which point the
// `comment` value is added to ReactionTargetType and a `commentId`
// FK is added below alongside `postId`.
//
// App-level invariants:
//   - When targetType='post', postId must equal targetId. The service
//     layer enforces this at write time.
//   - The (userId, targetType, targetId, emoji) unique constraint
//     makes add() idempotent — re-reacting with the same emoji is a no-op.
//
// onDelete choices:
//   - user: Cascade (when a user is hard-deleted their reactions go too;
//     soft-delete on the User keeps reactions intact)
//   - post: Cascade (when a post is hard-deleted its reactions go too;
//     posts use soft-delete in MVP so this rarely fires)

enum ReactionEmoji {
  candle // 🕯️ — vigil / remembrance / Shabbat
  pray // 🙏 — prayer / appreciation / thanks
  heart // ❤️ — solidarity / love
  strong // 💪 — strength / determination
  target // 🎯 — agreed / on-point
  sparkle // 💕 — warmth / community
  thumbsup // 👍 — acknowledged / understood
  sad // 😢 — grief / sympathy
}

enum ReactionTargetType {
  post
  comment // BU-comments / D052 — reactions on comments are schema-ready, UI deferred
}

model Reaction {
  id String @id @default(uuid())

  userId String
  user   User   @relation("authorReactions", fields: [userId], references: [id], onDelete: Cascade)

  targetType ReactionTargetType
  targetId   String

  postId String?
  post   Post?   @relation("postReactions", fields: [postId], references: [id], onDelete: Cascade)

  // BU-comments / D052 — nullable FK so post-targeted reactions remain
  // unaffected. When targetType='comment', commentId must equal targetId
  // (enforced at the service layer).
  commentId String?
  comment   Comment? @relation("commentReactions", fields: [commentId], references: [id], onDelete: Cascade)

  emoji ReactionEmoji

  createdAt DateTime @default(now())

  @@unique([userId, targetType, targetId, emoji], name: "one_emoji_per_user_per_target")
  @@index([targetType, targetId])
  @@index([postId, emoji])
  @@index([commentId, emoji])
}

// ─── Comment ─────────────────────────────────────────────────────────────────
//
// BU-comments (D052). Flat discussion thread on a post. Threaded replies
// (parentCommentId) deferred to a future BU. Edit / delete UX deferred —
// `deletedAt` exists for future soft-delete; no member-facing UI updates it
// in MVP.
//
// App-level invariants:
//   - Comments inherit the parent post's visibility — listCommentsForPost
//     applies the same visibility filter as listPosts at the parent level
//   - Body is 1–5000 chars (Zod-enforced); soft hint at 4000 in UI
//   - Soft-deleted comments are excluded from listCommentsForPost output
//
// onDelete choices:
//   - author: Restrict (mirrors Post.author — no hard-delete with comments;
//     soft-delete the user instead to preserve community history)
//   - post: Cascade (rare — posts use soft-delete in MVP; cascade prevents
//     orphans if a post is genuinely hard-deleted)

model Comment {
  id String @id @default(uuid())

  // BU-requests-vetting: Comment is now polymorphic — exactly one of
  // postId / requestId is non-null (app-level invariant; both nullable
  // at the DB level).
  postId String?
  post   Post?   @relation("postComments", fields: [postId], references: [id], onDelete: Cascade)

  requestId String?
  request   Request? @relation("requestComments", fields: [requestId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("commentAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  body String

  // Comment audience (BU-requests-foundation / D056). 'all' = visible to
  // submitter + reviewers; 'reviewers' = internal-only (vetting flow).
  // Default 'all' so existing post comments behave unchanged.
  audience CommentAudience @default(all)

  // D071 — when set, this is a system-authored comment with special
  // rendering. Currently used for `post_review_attribution` (auto-comment
  // posted when a reviewer publishes a post via the kind_review flow).
  // null = regular member comment, no special styling.
  systemKind CommentSystemKind?

  // Coord-board (Slice 3 — ADR-0007). Coexists with `audience` and
  // `systemKind`; service-layer dispatch table in ADR-0007.
  // `kind`: comment vs internal note (per-group visibility envelope).
  // `source`: human vs system (kanban transition events ride
  //   source = system).
  kind   CommentKind   @default(comment)
  source CommentSource @default(human)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Reactions on this comment (BU-comments / D052 — schema-ready, UI deferred)
  reactions Reaction[] @relation("commentReactions")

  @@index([postId, createdAt])
  @@index([requestId, createdAt])
  @@index([authorId, createdAt])
  @@index([deletedAt])
  @@index([requestId, kind, createdAt])
}

enum CommentAudience {
  all
  reviewers
}

// D071 — discriminates system-authored comments. Phase 1 ships one value;
// future system-comment kinds (e.g. `post_kind_changed`, `post_merged`)
// can be added without churn. null on the column = regular member comment.
enum CommentSystemKind {
  post_review_attribution
}

// ─── Notification ────────────────────────────────────────────────────────────
//
// BU-requests-vetting / D057. In-app notifications surfaced inside the
// Requests tab (Option B). Triggered by:
//   - @mention in a Request comment (NotificationType.request_mention)
//   - Request status transition (created/claimed/resolved)
//   - Send-for-Review approve/archive actions (D063)
//
// MVP: in-app polling only (no push, no email). Per-user notification
// preferences are deferred to BU-account.
model Notification {
  id              String @id @default(uuid())
  recipientUserId String
  recipient       User   @relation("notificationsReceived", fields: [recipientUserId], references: [id], onDelete: Cascade)

  type NotificationType

  // Optional polymorphic context — present when the notification refers
  // to a specific Request. (Future types may reference posts; currently
  // only Request-related notifications.)
  requestId String?
  request   Request? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  fromUserId String?
  fromUser   User?   @relation("notificationsSent", fields: [fromUserId], references: [id], onDelete: SetNull)

  message String?

  createdAt DateTime  @default(now())
  readAt    DateTime?

  // Coord-board (Slice 3 — ADR-0008). Coexists with `type` and `readAt`;
  // service-layer dispatch table in ADR-0008.
  // `lifecycle`: 3-state (new / acknowledged / dismissed). On
  //   acknowledge, services write BOTH lifecycle=acknowledged AND
  //   readAt=now() so legacy queries keep working.
  // `reasonKind`: trigger-shaped discriminator for kanban-era
  //   notifications. Nullable on legacy rows.
  lifecycle  NotificationLifecycle   @default(new)
  reasonKind NotificationReasonKind?

  @@index([recipientUserId, readAt, createdAt])
  @@index([requestId])
  @@index([recipientUserId, lifecycle, createdAt])
}

enum NotificationType {
  request_status_changed
  request_mention
  request_resolved
  request_published
  request_archived
}

// ─────────────────────────────────────────────────────────────────────────────
// SLICE 3 — Coordination board (bu-coordination-board / ADRs 0005-0009)
// ─────────────────────────────────────────────────────────────────────────────
//
// Build sequence #1 of 8: schema + ADRs only, no behaviour. Consumers
// land in PR #2 (services). All rows here are dormant until pilot teams
// flip `coord_board_v1` (registered, prod OFF, dev OFF by default).
//
// Slice content:
//   - Enums: GroupKind, CommentKind, CommentSource, NotificationLifecycle,
//     NotificationReasonKind, SubscriptionSource, RequestGroupOrigin.
//   - New entities: Assignment (multi-assignee), RequestGroup (cross-team
//     share with per-link state), GroupShareWorkflow (per-team allow-list),
//     BoardColumn (per-Group configurable columns), RequestSubscription
//     (subscriber registry per Request).
//   - Field additions on existing models live inline (Group.kind,
//     Request.columnId/boardPosition, Comment.kind/source,
//     Notification.lifecycle/reasonKind).
//
// Deferred to PR #2 (alongside consumer-service migration):
//   - Drop Request.claimedByUserId (replaced by Assignment join).
//   - Drop Request.requestType.
//   - Reframe RequestStatus enum to backlog | active | done | abandoned
//     (ADR-0005 documents the target shape).
//
// See bu-coordination-board.md v0.4 for the build sequence and the
// permission model.

// ─── Enums ───────────────────────────────────────────────────────────────────

enum GroupKind {
  workstream
  region
  network
  team
  topic
}

enum CommentKind {
  comment
  note
}

enum CommentSource {
  human
  system
}

enum NotificationLifecycle {
  new
  acknowledged
  dismissed
}

enum NotificationReasonKind {
  assignment
  mention
  status_change
  comment
  urgent_flip
  team_blast
}

enum SubscriptionSource {
  auto_author
  auto_assignee
  auto_mention
  explicit
  team_blast_optin
}

enum RequestGroupOrigin {
  originating
  workflow_share
  ad_hoc_share
}

// ─── Assignment ──────────────────────────────────────────────────────────────
//
// Multi-assignee join between Request and User (ADR-0009 references; per
// brief v0.4 schema additions). Replaces the single-owner pattern of
// Request.claimedByUserId — consumer-service migration in PR #2 drops the
// old column. Until then, both coexist.
//
// App-level invariants (PR #2 enforces):
//   - Self-assigning auto-subscribes (RequestSubscription created with
//     source = auto_assignee).
//   - Unassigning leaves any explicit subscription in place.
//   - First-assignee gets no special status (no "owner" vocabulary).
model Assignment {
  id        String  @id @default(uuid())
  requestId String
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation("userAssignments", fields: [userId], references: [id], onDelete: Cascade)

  assignedAt   DateTime  @default(now())
  unassignedAt DateTime?

  @@unique([requestId, userId])
  @@index([userId, unassignedAt])
  @@index([requestId, unassignedAt])
}

// ─── RequestGroup ────────────────────────────────────────────────────────────
//
// Per-link state for cross-team shares (ADR-0009). Each Request is linked
// to its originating group (origin = originating) plus zero or more shared
// groups (origin = workflow_share | ad_hoc_share). Each link carries its
// own column placement and urgent flag, so Writers and IT can have
// independent workflows on the same ticket.
//
// App-level invariants (PR #2 enforces):
//   - Exactly one row per Request has origin = originating.
//   - The originating row's columnId/boardPosition mirrors Request.columnId/
//     boardPosition.
//   - Soft-delete (deletedAt) is the "unshare" gesture; the row stays for
//     audit. Re-share creates a new row or undeletes.
model RequestGroup {
  id        String  @id @default(uuid())
  requestId String
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  groupId   String
  group     Group   @relation("groupRequests", fields: [groupId], references: [id], onDelete: Cascade)

  // Per-link state. Independent of Request's own columnId / boardPosition
  // (which mirror this row when origin = originating).
  columnId      String?
  column        BoardColumn? @relation("requestGroupColumn", fields: [columnId], references: [id], onDelete: SetNull)
  boardPosition Decimal?
  isUrgent      Boolean      @default(false)

  origin RequestGroupOrigin @default(originating)

  sharedByUserId String?
  sharedBy       User?   @relation("requestGroupSharedBy", fields: [sharedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([requestId, groupId])
  @@index([groupId, deletedAt])
  @@index([requestId])
  @@index([groupId, columnId, boardPosition])
}

// ─── GroupShareWorkflow ──────────────────────────────────────────────────────
//
// Per-team admin allow-list of share targets (ADR-0009). Constrains the
// "Share with team" picker on Surface 2 — admin-pre-set targets surface
// first; ad-hoc share to any group is gated separately by role.
//
// App-level invariants:
//   - sourceGroupId != targetGroupId (a group cannot share to itself).
//     PR #2 service enforces; not at DB level (no CHECK in Prisma 5).
//   - Soft-delete preserves audit; re-add creates a new row or undeletes.
model GroupShareWorkflow {
  id            String @id @default(uuid())
  sourceGroupId String
  sourceGroup   Group  @relation("workflowSources", fields: [sourceGroupId], references: [id], onDelete: Cascade)
  targetGroupId String
  targetGroup   Group  @relation("workflowTargets", fields: [targetGroupId], references: [id], onDelete: Cascade)

  addedByUserId String?
  addedBy       User?   @relation("groupShareWorkflowsAdded", fields: [addedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([sourceGroupId, targetGroupId])
  @@index([sourceGroupId, deletedAt])
  @@index([targetGroupId, deletedAt])
}

// ─── BoardColumn ─────────────────────────────────────────────────────────────
//
// Per-Group configurable kanban column (ADR-0006). Defaults seeded by
// service hook on Group creation in PR #2; default sets per GroupKind
// live in shared/board-column-defaults.ts.
//
// App-level invariants (PR #2 enforces):
//   - ordinal is 0-based and contiguous within a Group; reorder updates
//     ordinals atomically.
//   - displayName non-empty.
//   - Cards on a deleted column must be relocated by an admin before the
//     column is hard-deleted; soft-delete (deletedAt) is the normal path.
model BoardColumn {
  id          String @id @default(uuid())
  groupId     String
  group       Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  ordinal     Int
  displayName String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  requests          Request[]
  requestGroupCells RequestGroup[] @relation("requestGroupColumn")

  @@unique([groupId, ordinal])
  @@index([groupId, deletedAt])
}

// ─── RequestSubscription ─────────────────────────────────────────────────────
//
// Subscriber registry per Request (bu-coordination-board v0.4 — schema
// additions). Drives Surface 3 notification fan-out (Tier-2 default #4 +
// #10: author + assignees + ever-mentioned + manually-subscribed).
//
// Note: the brief calls this "existing RequestSubscription" but no model
// existed pre-PR; this introduces it. Acknowledged in PR #1 prep.
//
// App-level invariants (PR #2 enforces):
//   - Auto-rules (auto_author / auto_assignee / auto_mention) populate
//     this table from service-side hooks; explicit gestures use source
//     = explicit.
//   - Unsubscribing soft-deletes (deletedAt) — preserves history of
//     "they were subscribed and deliberately left."
//   - team_blast_optin records subscriber-driven opt-in to team-wide
//     blast notifications (Surface 3 trigger rules).
model RequestSubscription {
  id        String  @id @default(uuid())
  requestId String
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation("userSubscriptions", fields: [userId], references: [id], onDelete: Cascade)

  source SubscriptionSource

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([requestId, userId])
  @@index([userId, deletedAt])
  @@index([requestId, deletedAt])
}
